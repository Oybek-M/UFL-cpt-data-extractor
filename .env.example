# Ushbu faylni .env nomi bilan nusxalang va haqiqiy qiymatlarni kiriting.
# .env HECH QACHON git'ga commit qilinmaydi (.gitignore da).

# Hugging Face token (Gemma-4 tokenizer/model yuklash uchun kerak bo'lishi mumkin)
HF_TOKEN=

# Web UI'da ilova darajasida auth yo'q (kichik jamoa, 2-3 kishi).
# VPS'da tashqariga chiqarganda himoya Nginx Basic Auth orqali qo'yiladi — docs/DOCKER.md §2.5 ga qarang.

# Tokenizer sozlamalari (config/ufl.toml dagi qiymatlarni override qiladi, ixtiyoriy)
UFL_TOKENIZER_MODEL_ID=google/gemma-4-4b-it
